{
  "manifest_version": 3,
  "name": "Timetable Printer",
  "version": "1.9",
  "description": "Print student and staff timetables from the student information system",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.compass.education/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.compass.education/Records/UserNew.aspx*"],
      "js": ["injector.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Timetable Printer Settings",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["print.html", "print.js", "interceptor.js"],
      "matches": ["*://*.compass.education/*"]
    }
  ]
}